{
  "name": "death-markers-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute death-markers --local --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute death-markers --remote --file=./schema.sql",
    "db:seed:local": "wrangler d1 execute death-markers --local --file=./seed.sql",
    "db:query:local": "wrangler d1 execute death-markers --local --command \"SELECT * FROM markers ORDER BY created_at DESC LIMIT 20\""
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "wrangler": "^4.43.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0"
  }
}
